{
    "name": "aurora/ai-pipeline",
    "description": "AI processing pipelines with queue-based execution for Aurora CMS",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {"type": "path", "url": "../cache"},
        {"type": "path", "url": "../plugin"},
        {"type": "path", "url": "../typed-data"},
        {"type": "path", "url": "../config"},
        {"type": "path", "url": "../entity"},
        {"type": "path", "url": "../queue"}
    ],
    "require": {
        "php": ">=8.3",
        "aurora/entity": "@dev",
        "aurora/queue": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Aurora\\AI\\Pipeline\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aurora\\AI\\Pipeline\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
